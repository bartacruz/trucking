<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_partner_kanban_trucking" model="ir.ui.view">
        <field name="name">res.partner.kanban.trucking</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <!-- 'group_create="false"' evita que el usuario cree nuevos estados manualmente -->
            <!-- 'group_edit="false"' y 'group_delete="false"' mantienen la estructura fija -->
            <kanban default_group_by="trucking_state"
                class="o_res_partner_kanban"
                group_create="false"
                group_edit="false"
                group_delete="false"
                records_draggable="true">
                <field name="trucking_sequence" widget="handle" />
                <field name="trucking_state" />
                <field name="active_trucking_trip_id" />
                <field name="active_trucking_trip_state" invisible="1" />

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click p-2">
                            <div class="oe_kanban_details">
                                <!-- 1ra Línea: Nombre (Protagonista) -->
                                <div
                                    t-attf-class="o_kanban_record_title #{record.trucking_state.raw_value == 'unavailable' ? 'text-muted' : 'fw-bold fs-5'}">
                                    <field name="name" />
                                </div>

                                <!-- 2da Línea: Contenedor Flex -->
                                <div class="d-flex justify-content-between align-items-center mt-1">

                                    <!-- Izquierda: Vehículo y Trailer (Muteados para jerarquía visual) -->
                                    <div class="o_kanban_record_subtitle text-muted text-truncate pe-2">
                                        <i class="fa fa-truck me-1 opacity-75" />
                                        <field name="vehicle_id" />
                                        <t t-if="record.trailer_id.raw_value">
                                            <span class="ms-1">/</span>
                                            <span class="ms-1">
                                                <field name="trailer_id" />
                                            </span>
                                        </t>
                                    </div>

                                    <!-- Derecha: Badge del Viaje (Compacto y más liviano) -->
                                    <div t-if="record.active_trucking_trip_id.raw_value">
                                        <t t-set="badge_class" t-value="'bg-secondary opacity-75'" />
                                        <t t-if="record.active_trucking_trip_state.raw_value == 'assigned'" t-set="badge_class"
                                            t-value="'bg-info text-white'" />
                                        <t t-if="record.active_trucking_trip_state.raw_value == 'started'" t-set="badge_class"
                                            t-value="'bg-warning text-dark'" />
                                        <t t-if="record.active_trucking_trip_state.raw_value == 'arrived'" t-set="badge_class"
                                            t-value="'bg-success text-white'" />

                                        <!-- Ajustamos padding (py-0 px-2) y peso de fuente (fw-normal) -->
                                        <span t-attf-class="badge rounded-pill #{badge_class} py-0 px-2 fw-normal"
                                            style="font-size: 0.75rem; line-height: 1.4;">
                                            <i class="fa fa-road me-1 small" />
                                            <field name="active_trucking_trip_id" />
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>

                </templates>
            </kanban>
        </field>
    </record>

    <record id="res_partner_view_sale_buttons" model="ir.ui.view">
        <field name="name">partner.view.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="sale.res_partner_view_buttons" />
        <field name="arch" type="xml">
            <button name="action_view_sale_order" position="attributes">
                <attribute name="invisible">sale_order_count == 0</attribute>
            </button>
        </field>
    </record>
    <record id="res_partner_view_purchase_buttons" model="ir.ui.view">
        <field name="name">partner.view.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="purchase.res_partner_view_purchase_buttons" />
        <field name="arch" type="xml">
            <button name="526" position="attributes">
                <attribute name="invisible">purchase_order_count == 0</attribute>
            </button>
        </field>
    </record>

    <record id="res_partner_view_purchase_buttons_inherit" model="ir.ui.view">
        <field name="name">res.partner.purchase.form.inherit.tms</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="purchase_stock.res_partner_view_purchase_buttons_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='%(purchase_stock.action_purchase_vendor_delay_report)d']" position="replace"/>    
        </field>
    </record>


    <record id="res_partner_view_account_buttons" model="ir.ui.view">
        <field name="name">partner.view.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.partner_view_buttons" />
        <field name="arch" type="xml">
            <button name="action_view_partner_invoices" position="attributes">
                <attribute name="invisible">total_invoiced == 0</attribute>
            </button>
        </field>
    </record>
    <record id="view_partner_view_buttons" model="ir.ui.view">
        <field name="name">partner.view.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_trucking_trips"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-truck"
                    invisible="trucking_trip_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <!-- CASO 1: Con Viaje Activo (Verde) -->
                        <div invisible="not active_trucking_trip_id" class="text-success font-weight-bold">
                            <span class="o_stat_text">Viajes</span>
                            <field name="trucking_trip_count" class="text-success o_stat_value" />

                        </div>

                        <!-- CASO 2: Sin Viaje Activo (Estándar) -->
                        <div invisible="active_trucking_trip_id">
                            <span class="o_stat_text">Viajes</span>
                            <field name="trucking_trip_count" class="o_stat_value" />

                        </div>
                    </div>
                </button>

                <button name="action_view_sale_lines"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-list-ul"
                    invisible="sale_order_line_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Lineas de Venta</span>
                        <field name="sale_order_line_count" class="o_stat_value" />
                    </div>
                </button>

            </div>
        </field>
    </record>

    <record id="view_partner_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.trucking</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <field name="function" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="website" position="attributes">
                <attribute name="invisible">truck_driver</attribute>
            </field>
            <field name="title" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <xpath expr="//field[@name='category_id']" position="replace">
                <field name="truck_driver" invisible="not active_model == 'res.partner' or is_company" />
                <field name="vehicle_id" invisible="not truck_driver" />
                <field name="trailer_id" invisible="not truck_driver" />
                <field name="active_trucking_trip_id" readonly="1" invisible="not truck_driver or not active_trucking_trip_id" />
            </xpath>

            <xpath expr="//group/group" position="inside">
                <field name="invoice_partner_id" />
                <field name="category_id" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"
                    placeholder='e.g. "B2B", "VIP", "Consulting", ...' />
            </xpath>
            
                <xpath expr="//page[@name='contact_addresses']" position="before">
                <page string="Invoice Partners" name="invoice_partners">
                    <field name="invoice_partner_ids" widget="many2many"
                        mode="kanban"
                        context="{'default_invoice_partner_id': active_id, 'search_view_ref': 'base.view_res_partner_filter'}">
                        <kanban>
                            <field name="id" />
                            <field name="display_name" />
                            <field name="vat" />
                            <field name="l10n_ar_formatted_vat" />
                            <field name="phone" />
                            <field name="mobile" />
                            <templates>
                                <t t-name="kanban-box">
                                    <div class="oe_kanban_global_click">
                                        <div class="oe_kanban_details">
                                            <strong class="o_kanban_record_title">
                                                <field name="display_name" />
                                            </strong>
                                            <div t-if="record.l10n_ar_formatted_vat.value">
                                                <t t-esc="record.l10n_ar_formatted_vat.value" />
                                            </div>
                                            <div t-if="record.phone.value">
                                                <field name="phone" widget="phone" />
                                            </div>
                                            <div t-if="record.mobile.value">
                                                <field name="mobile" widget="phone" />
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </page>
            </xpath>

            <!-- <xpath expr="//page[@name='contact_addresses']" position="attributes">
                <attribute name="autofocus" position="replace/" />
            </xpath> -->
            <!-- <xpath expr="//page[@name='contact_addresses']" position="before">
                <page name="trucking" string="Trucking" invisible="not truck_driver">
                    <group>
                        <group>
                            <field name="vehicle_id" />
                            <field name="trailer_id" />
                        </group>
                        <group>
                            
                        </group>
                    </group>
                </page>
            </xpath> -->

        </field>
    </record>
    <record id="view_res_partner_search_trucking" model="ir.ui.view">
        <field name="name">res.partner.search.trucking</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Driver" />
                <field name="vehicle_id" />
                <field name="active_trucking_trip_id" />

                <filter string="Available" name="available" domain="[('trucking_state', '=', 'available')]" />
                <filter string="Assigned" name="assigned" domain="[('trucking_state', '=', 'assigned')]" />
                <filter string="Unavailable" name="unavailable" domain="[('trucking_state', '=', 'unavailable')]" />
                <separator />
                <filter string="No Vehicle" name="no_vehicle" domain="[('vehicle_id','=',False)]" />
                <group expand="0" string="Group By...">
                    <filter string="Driver State" name="group_trucking_state" context="{'group_by': 'trucking_state'}" />
                </group>
            </search>
        </field>
    </record>


    <record id="action_truck_drivers_kanban" model="ir.actions.act_window">
        <field name="name">Drivers Board</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_res_partner_search_trucking" />
        <field name="domain">[('truck_driver', '=', True)]</field>
        <field name="context">{
            'default_truck_driver': True,
            'search_default_group_trucking_state': 1
            }</field>
        <field name="view_ids"
            eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_res_partner_kanban_trucking')}),
                (0, 0, {'view_mode': 'tree'}),
                (0, 0, {'view_mode': 'form'})
             ]" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Organize your driver's fleet.
            </p>
        </field>
    </record>

</odoo>
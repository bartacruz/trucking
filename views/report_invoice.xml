<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_invoice_document_inherit_trucking" inherit_id="account.report_invoice_document">
        
        <!-- 1. Agregar el encabezado de la columna -->
        <xpath expr="//table[@name='invoice_line_table']/thead/tr/th[@name='th_description']" position="before">
            <th name="th_product_category" class="text-start"><span>Product</span></th>
        </xpath>

        <!-- 2. Agregar el valor del campo en las líneas -->
        <xpath expr="//table[@name='invoice_line_table']/tbody//tr//td[@name='account_invoice_line_name']" position="before">
            <td>
                <span t-field="line.product_category_id.name"/>
            </td>
        </xpath>

    </template>
</odoo>

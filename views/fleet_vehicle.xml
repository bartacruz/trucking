<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_vehicle_form_inherit_truck" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.truck</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form" />
        <field name="arch" type="xml">
            <field name="driver_id" position="after">
                <field name="truck_driver_id"></field>
            </field>
            <xpath expr="//group" position="inside">
                <group string="Equipment" name="trailer_rel_group">
                    <field name="trailer_id" invisible="vehicle_type != 'truck'" />
                    <field name="truck_id" invisible="vehicle_type != 'trailer'" />

                </group>
            </xpath>

            <xpath expr="//field[@name='driver_id']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
        </field>
    </record>
    
    <record id="fleet_vehicle_view_kanban" model="ir.ui.view">
        <field name="name">fleet.vehicle.kanban.trucking</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_kanban" />
        <field name="arch" type="xml">
            <kanban position="attributes">
                <attribute name="default_group_by" position="replace" />
                <attribute name="default_groupby_vehicle_type">1</attribute>
            </kanban>
            <div class="o_kanban_record_bottom" position="before">
                <t t-if="record.vehicle_type.raw_value == 'truck' and record.trailer_id.raw_value">
                    <div class="d-flex align-items-baseline">
                        <i class="fa fa-chevron-circle-left me-1"/>
                        <field name="trailer_id" />
                    </div>
                </t>
                <t t-if="record.vehicle_type.raw_value == 'trailer' and record.truck_id.raw_value">
                    <div class="d-flex align-items-baseline">
                        <i class="fa fa-truck me-1"/>
                        <field name="truck_id" />
                    </div>
                </t>
            </div>
            <field name="id" position="after">
                <field name="vehicle_type" />
                <field name="truck_driver_id" />
                <field name="truck_id" />
                <field name="trailer_id" />
            </field>

            <xpath expr="//t[@t-if='record.driver_id.raw_value']" position="after">
                <t t-if="record.truck_driver_id.raw_value">
                    <field name="truck_driver_id" widget="many2one_avatar" options="{'display_avatar_name': True}" />
                </t>
            </xpath>


        </field>
    </record>
    <record id="fleet_vehicle_view_search_trucking" model="ir.ui.view">
        <field name="name">fleet.vehicle.search.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_search" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='cars']" position="replace">
                <filter string="Cars" name="cars" domain="[('vehicle_type', '=', 'car')]" />
                <filter string="Camiones" name="cargos" domain="[('vehicle_type', '=', 'truck')]" />
                <filter string="Trailers" name="trailers" domain="[('vehicle_type', '=', 'trailer')]" />
            </xpath>
            <xpath expr="//filter[@name='bikes']" position="replace" />
            <xpath expr="//filter[@name='trailer_hook']" position="replace"></xpath>
            <filter name="available" position="replace">
                <filter string="Assigned" name="assigned"
                    domain="['|',('driver_id', '!=', False),('truck_driver_id', '!=', False)]" />
                <filter string="Unassigned" name="unassigned" domain="[('driver_id', '=', False),('truck_driver_id', '=', False)]" />
            </filter>
            <filter name="planned" position="replace" />
            <filter name="groupby_status" position="before">
                <filter string="Vehicle Type" name="groupby_vehicle_type" context="{'group_by': 'vehicle_type'}" />
            </filter>
        </field>
    </record>
</odoo>
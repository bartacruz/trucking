<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_trucking_view_kanban" model="ir.ui.view">
        <field name="name">sale_order.trucking.view.kanban</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <kanban
                class="o_kanban_dashboard o_emphasize_colors"
                group_create="False"
                group_edit="False"
                create="0"
                js_class="trucking_kanban"
                default_order="commitment_date desc"
            >
                <field name="partner_id" />
                <field name="partner_invoice_id" />
                <field name="origin_locality_id" />
                <field name="destination_locality_id" />
                <field name="trucking_trip_ids" />
                <field name="tag_ids" />
                <field name="trucking_trip_active" />

                <header>
                    <button name="%(trucking.actrion_create_so)d"
                        type="action"
                        class="btn-primary o_button_create_trucking_sale"
                        string="New Trucking Order" display="always" />
                </header>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">

                                <div class="text-muted o_row d-flex justify-content-end">
                                    <field name="commitment_date" widget="datetime" options="{'show_time': false}" />
                                </div>

                                <div class="o_kanban_record_top mb-0">
                                    <div class="o_kanban_record_headings">
                                        <div class="mb-2">
                                            <strong class="o_kanban_record_title">
                                                <field name="partner_id" />
                                            </strong>
                                        </div>
                                        <div class="text-muted o_row">
                                            <field name="origin_locality_id" />
                                            <i class="fa fa-long-arrow-right mx-2 oe_read_only" title="->" />
                                            <field name="destination_locality_id" />
                                        </div>

                                        <t t-if="record.partner_invoice_id.raw_value != record.partner_id.raw_value">
                                            <div>
                                                <span>For:</span>
                                                <field name="partner_invoice_id" context="{'show_alias':True}" />
                                            </div>
                                        </t>
                                        <field name="tag_ids" widget="many2many_tags" />
                                    </div>

                                </div>

                                <div class="o_kanban_record_body">
                                    <div class="o_trucking_orders o_row w-100 mt-1">
                                        <field name="trucking_trip_ids" widget="trucking_trips"
                                            options="{'color_field': 'color'}"
                                            class="w-100" />
                                    </div>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.trucking</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <header position="inside">
                <button type="object" name="action_to_draft" string="To Draft" class="btn btn-warning" invisible="state != 'sale'"
                    help="Sets this sale order's state to 'Draft' so it can be edited further\n\nIt doesn't affect trips." />
                <field name="trucking_trips_count" invisible="1" />
                <field name="has_trucking_trips" invisible="1" />
            </header>
            <xpath expr="//field[@name='has_active_pricelist']" position="before">
                <field name="commitment_date" invisible="not has_trucking_trips" />
            </xpath>
            <div groups="product.group_product_pricelist"
                position="after">
                <label for="pricelist_discount"
                    string="Descuento Tarifa"
                    invisible="not pricelist_id" />
                <div class="d-flex w-25"
                    invisible="not pricelist_id"
                    help="Porcentaje de descuento que se aplica sobre la tarifa base.">
                    <span class="text-danger fw-bold">-</span>
                    <field name="pricelist_discount"
                        class="oe_inline"
                        style="width: 60px !important; flex: none;"
                        placeholder="0.00" />
                    <span class="fw-bold">%</span>
                </div>
                <field name="trucking_fixed_price" invisible="pricelist_id" />
            </div>


            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Viajes" name="trucking_trips" invisible='not has_trucking_trips' icon="fa-truck">
                    <group>
                        <group>
                            <field name="origin_locality_id" />
                        </group>
                        <group>
                            <field name="destination_locality_id" />
                        </group>
                    </group>
                    <button type="object" name="action_new_trip_sale" class="btn btn-primary btn-sm" string="New Trip" />
                    <field name="trucking_trip_ids"
                        context="{'show_trip_open_button': True, 'default_order': 'is_active desc, id desc'}" />
                </page>
            </xpath>
            <xpath expr="//list//field[@name='name']" position="after">
                <field name="trucking_trip_id" column_invisible="not parent.has_trucking_trips" optional="hide" />


                <field name="trucking_trip_state" widget="badge"
                    decoration-primary="trucking_trip_state in ['assigned','confirmed','started','arrived']"
                    decoration-success="trucking_trip_state == 'completed'"
                    decoration-danger="trucking_trip_state == 'cancelled'"
                    decoration-info="trucking_trip_state=='draft'"
                    optional="show"
                />


                <field name="distance" column_invisible="not parent.has_trucking_trips" optional="show" />

            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_trucking_trips"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-truck"
                    invisible="not has_trucking_trips"
                >
                    <div class="o_stat_info">
                        <span class="o_stat_text">Trips</span>
                        <field name="trucking_trips_count" class="o_stat_value" />

                        <field name="trucking_trip_ids" invisible="1" />
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_trucking_search" model="ir.ui.view">
        <field name="name">sale.order.trucking.search</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id" />
                <field name="partner_invoice_id" />
                <field name="name" />
                <field name="trucking_trip_ids" />
                <field name="origin_locality_id" />
                <field name="destination_locality_id" />

                <filter string="My Orders" domain="[('user_id', '=', uid)]" name="my_trucking_sale_orders_filter" />
                
                
                <group name="sale_dates" string="Fecha">
                    <filter string="Fecha de la orden" name="commitment_filter" date="commitment_date" />
                    <filter string="Today" name="filter_today_creation"
                        domain="[('create_date','&gt;', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]" />
                    <filter string="7 days" name="filter_week_creation"
                        domain="[('create_date','&gt;', (context_today() - datetime.timedelta(weeks=1)).strftime('%Y-%m-%d'))]" />
                    <filter string="30 days" name="filter_mont_creation"
                        domain="[('create_date','&gt;', (context_today() - datetime.timedelta(months=1)).strftime('%Y-%m-%d'))]" />
                </group>
                <filter string="Active" name="trucking_actives" domain="[('trucking_trip_active', '=', True)]" />
                <filter string="To Assign" name="trucking_to_assign" domain="[('trucking_trips_to_assign', '&gt;', 0)]" />
            </search>
        </field>
    </record>

    <record id="action_trucking_dash_sale" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">sale.order</field>
        <field name="search_view_id" ref="view_sale_order_trucking_search" />
        <field name="context">
            {
            "search_default_filter_week_creation":True,
            'remember_filters': True,
            }
        </field>
        <field name="domain">[('has_trucking_trips','=',True)]</field>
        <field name="view_mode">kanban,list,form</field>
        <field
            name="view_ids"
            eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('sale_order_trucking_view_kanban')}),
            ]"
        />
    </record>

    <record id="action_export_sol_with_trips" model="ir.actions.server">
        <field name="name">Exportar Líneas (con Viajes)</field>
        <field name="model_id" ref="sale.model_sale_order" />
        <field name="binding_model_id" ref="sale.model_sale_order" />
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if not record.order_line:
    raise UserError("La orden no tiene líneas para exportar.")

action = {
    'type': 'ir.actions.act_window',
    'name': 'Exportar Líneas con Viajes',
    'res_model': 'base.export',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'active_model': 'sale.order.line',
        'active_ids': record.order_line.ids,
        # 'export_id': env.ref('tu_modulo.id_de_tu_plantilla').id,
    },
}

        </field>
    </record>

</odoo>
<odoo>

    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">product.template.form.inherit.trucking</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <div name="options" position="inside">
                <span class="d-inline-block" invisible="type != 'service'">
                    <field name="trucking_trip" />
                    <label for="trucking_trip" />
                </span>
            </div>
        </field>
    </record>
    <record id="action_trucking_data_product" model="ir.actions.act_window">
        <field name="name">Trip Products</field>
        <field name="res_model">product.template</field>
        <field name="context">{
            'default_type':'service',
            'default_trucking_trip':1,
        }
        </field>
        <field name="domain">[('trucking_trip','=',True)]</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
    
</odoo>

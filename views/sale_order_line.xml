<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="sale_order_line_tree" model="ir.ui.view">
        <field name="name">model.name.view.form.inherit</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale_order_line_menu.sale_order_line_tree" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="cpe" optional="show" />
            </field>
            <field name="product_id" position="attributes">
                <attribute name="optional">show</attribute>
            </field>
        </field>


    </record>
    
    <record id="sale_order_line_search" model="ir.ui.view">
        <field name="name">sale.order.line.search</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_sales_order_line_filter" />
        <field name="arch" type="xml">
            <field name="order_id" position="before">
                <field name="cpe" />
            </field>
        </field>
    </record>

    <record id="model_sale_order_line_action_invoice" model="ir.actions.server">
        <field name="name">Crear Factura Consolidada</field>
        <field name="model_id" ref="sale.model_sale_order_line" />
        <field name="binding_model_id" ref="sale.model_sale_order_line" />
        <field name="state">code</field>
        <field name="code">
            action = records.action_invoice_selected_lines()
        </field>
    </record>
</odoo>
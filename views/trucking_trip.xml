<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="trucking_trip_view_tree" model="ir.ui.view">
        <field name="name">trucking.trip.view.tree</field>
        <field name="model">trucking.trip</field>
        <field name="arch" type="xml">
            <tree string="" decoration-muted="state=='cancelled'">
                <field name="name" />
                <field name="is_active" optional="hide" />
                <field name="cancelled" optional="hide" />
                <field name="commitment_date" />
                <field name="sale_id" optional="hide" />
                <field name="customer_id" optional="hide" />
                <field name="origin_locality_id" optional="show" />
                <field name="destination_locality_id" optional="show" />
                <field name="driver_id" />
                <field name="vehicle_id" optional="show" />
                <field name="trailer_id" optional="show" />
                <field name="start_date" optional="hide" />
                <field name="end_date" optional="hide" />
                <field name="cpe_id" optional="show" />
                <field name="state" widget="badge"
                    decoration-primary="is_active" 
                    decoration-success="state == 'completed'" 
                    decoration-danger="state == 'cancelled'" 
                    decoration-info="state=='draft'" />
                <button 
                    name="action_open_trip_form" 
                    type="object" 
                    icon="fa-external-link" 
                    title="Open Trip" 
                    invisible="not context.get('show_trip_open_button')"
                />
            </tree>
        </field>
    </record>

    <record id="trucking_trip_view_form" model="ir.ui.view">
        <field name="name">trucking.trip.view.form</field>
        <field name="model">trucking.trip</field>
        <field name="arch" type="xml">
            <form string="">
                <field name="is_active" invisible="1" />
                <field name="cpe_mismatch" invisible="1" />
                <div class="alert alert-warning" role="alert" invisible="not cpe_mismatch" >Warning: Vehicle from CPE mismatches the one in the order.</div>
                <header>
                    <button
                        name="action_cancel_trip"
                        type="object"
                        string="Cancel"
                        class="btn btn-danger text-uppercase"
                        invisible="state == 'cancelled'"
                    />
                    <button
                        name="action_enable_trip"
                        type="object"
                        string="Activate"
                        class="btn btn-warning text-uppercase"
                        invisible="state != 'cancelled'"
                    />
                    <button
                        name="action_end_trip"
                        type="object"
                        string="End Trip"
                        class="btn btn-primary text-uppercase"
                        invisible="state != 'started'"
                    />
                    <button
                        name="action_start_trip"
                        type="object"
                        string="Start Trip"
                        class="btn btn-primary text-uppercase"
                        invisible="state not in ['assigned','confirmed']"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        options="{'clickable':False}"
                    />
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">

                        <button
                            name="action_view_sales"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-usd"
                            invisible="not sale_id"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_text">Sale Order</span>
                                <field name="sale_id" class="o_stat_value" />
                            
                                <field name="sale_line_id" invisible="1" />
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h2>
                            <field name="name" class="oe_edit_only" string="Trip Name" nolabel="1" />
                        </h2>
                    </div>
                    <group>
                        <group>
                            <label for="customer_id"/>
                            <div class="mb-1">
                                <field name="customer_id" />
                                <field name="contact_phone" widget="phone" />
                            </div>
                            <field name="partner_id" invisible="customer_id == partner_id"/>
                            <field name="commitment_date" />
                            <field name="origin_locality_id" />
                            <field name="destination_locality_id" />
                        </group>

                        <group>
                            <label for="driver_id" />
                            <div class="mb-1">
                                <field name="driver_id" />
                                <field name="driver_phone" widget="phone" />
                                <div class="d-flex">
                                    <button
                                        type="object"
                                        name="action_send_whatsapp_request"
                                        class="btn btn-sm btn-warning text-nowrap mx-auto"
                                        icon="fa-whatsapp"
                                        invisible="state != 'assigned' or not driver_phone">
                                        Ask Confirmation
                                    </button>
                                    <button
                                        type="object"
                                        name="action_send_whatsapp_remember_cpe"
                                        class="btn btn-sm btn-warning text-nowrap mx-auto"
                                        icon="fa-whatsapp"
                                        invisible="cpe_id or state not in ['confirmed','started','arrived'] or not driver_phone">
                                        Remember CPE
                                    </button>
                                    <button 
                                        type="object" 
                                        name="action_confirm_driver" 
                                        class="btn btn-sm btn-primary text-nowrap mx-auto"
                                        invisible="state != 'assigned'">
                                        Confirm
                                    </button>
                                </div>
                            </div>

                            <label for="vehicle_id" string="Vehicle" />
                            <div class="d-flex w-75">
                                <field name="vehicle_id" readonly="cpe_id or state in ['completed','cancelled']" title="Vehicle" />
                                <span>-</span>
                                <field name="trailer_id" readonly="cpe_id or state in ['completed','cancelled']" title="Trailer" />
                            </div>
                            <label for="cpe_id" string="Carta de Porte" />
                            <div>
                                <field name="cpe_id" />
                                <div class="d-flex"  invisible="not cpe_status_date">
                                    <span>Fecha:</span>
                                    <field name="cpe_status_date" />
                                </div>
                                <field name="cpe_pdf" widget="attachment_link" nolabel="1" invisible="not cpe_pdf" />
                            </div>
                        </group>
                        <group>
                            <field name="start_date" />
                            <field name="arrived_date" />
                            <field name="end_date" />
                            <label for="distance" />
                            <div name="distance-val" class="d-flex w-25">
                                <field name="distance" class="text-end" />
                                <span class="ms-1">Kms</span>
                            </div>
                        </group>
                        <group>
                            <label for="delivered_cpe" invisible="not cpe_id" />
                            <div name="delivered_cpe-val" class="d-flex w-25" invisible="not cpe_id">
                                <field name="delivered_cpe" class="text-end"/>
                                <span class="ms-1">Kg</span>
                            </div>
                            <label for="delivered" />
                            <div name="delivered-val" class="d-flex w-25">
                                <field name="delivered" class="text-end" />
                                <span class="ms-1">Kg</span>
                            </div>

                            <label for="delivered_diff" invisible="not delivered_diff" />
                            <div name="delivered_diff-wrap" class="d-flex w-25" invisible="not delivered_diff">
                                <div name="delivered_diff-val" class="d-flex" >
                                    <field name="delivered_diff" class="text-end" />
                                    <span class="ms-1">Kg</span>
                                </div>
                            </div>
                            <label for="delivered_to_invoice" />
                            <div class="w-25">
                                <div name="delivered_to_invoice-val" class="d-flex">
                                    <field name="delivered_to_invoice" class="text-end" />
                                    <span class="ms-1">Kg</span>
                                </div>
                            </div>

                            <field name="rate_label" />
                        </group>

                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>
    <record id="view_trucking_trip_search" model="ir.ui.view">
        <field name="name">trucking.trip.search</field>
        <field name="model">trucking.trip</field>
        <field name="arch" type="xml">
            <search string="Búsqueda de Viajes">
                <!-- 1. Campos Buscables (Orden solicitado) -->
                <field name="name" string="Trip Name" />
                <field name="partner_id" string="Solicitor" />
                <field name="customer_id" string="Customer" />
                <field name="driver_id" string="Driver" />
                <field name="origin_locality_id" string="Origin Locality" />
                <field name="destination_locality_id" string="Destination Locality" />
                <field name="cpe_id" string="CPE" />
                <field name="sale_id" string="Sale Order" />
                <field name="vehicle_id" string="Vehicle" />
                <field name="commitment_date"/>
                <field name="end_date" filter_domain="[('end_date', '&gt;=', self), ('end_date', '&lt;=', self)]"/>
                <separator />

                <filter string="Active Trips" name="active" domain="[('is_active', '=', True)]" />
                <separator />
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]" />
                <filter string="Assigned" name="state_assigned" domain="[('state', '=', 'assigned')]" />
                <filter string="Confirmed" name="state_confirmed" domain="[('state', '=', 'confirmed')]" />
                <filter string="Started" name="state_started" domain="[('state', '=', 'started')]" />
                <filter string="Arrived" name="state_arrived" domain="[('state', '=', 'arrived')]" />
                <filter string="Completed" name="state_completed" domain="[('state', '=', 'completed')]" />
                <filter string="Cancelled" name="state_cancelled" domain="[('state', '=', 'cancelled')]" />

                <separator />

                <filter string="Fecha de la orden" name="commitment_filter" date="commitment_date" />
                <filter string="Fecha de Inicio" name="start_date_filter" date="start_date" />
                <filter string="Fecha de Finalización" name="end_date_filter" date="end_date" />
                <filter string="Today" name="today"
                    domain="[('commitment_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))), ('commitment_date', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]" />

                <separator />

                <group expand="0" string="Agrupar por...">
                    <filter string="Sale" name="group_sale" context="{'group_by': 'sale_id'}" />
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                    <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}" />
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}" />
                    <filter string="Customer" name="group_partner" context="{'group_by': 'customer_id'}" />
                    <filter string="Solicitor" name="group_partner" context="{'group_by': 'partner_id'}" />
                    <filter string="Date" name="group_date" context="{'group_by': 'commitment_date:month'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_trucking_trips" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">trucking.trip</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_trucking_trip_search" />
        <field name="context">{'remember_filters': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first trucking trip
            </p>
        </field>
    </record>
    <record id="ir_action_server_action_update_from_cpe" model="ir.actions.server">
        <field name="name">Update from CPE</field>
        <field name="model_id" ref="trucking.model_trucking_trip" />
        <field name="binding_model_id" ref="trucking.model_trucking_trip" />
        <field name="binding_view_types">form</field>
        <field name="groups_id" eval="[Command.link(ref('base.group_system'))]" />
        <field name="state">code</field>
        <field name="code">
            action = record.action_update_from_cpe()
        </field>
    </record>
</odoo>
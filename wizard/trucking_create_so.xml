<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="trucking_create_so_form" model="ir.ui.view">
        <field name="name">Create Sale</field>
        <field name="model">trucking.create.so</field>
        <field name="arch" type="xml">
            <form string="Create Sale">
                <field name="order_confirmed" invisible="1"/>
                <div class="oe_title">
                    <label for="partner_id" class="oe_edit_only" string="Customer" />
                    <h2>
                        <field name="partner_id" widget="res_partner_many2one" domain="[('is_company','=',True),('parent_id','=',None)]" context = "{'show_alias':True}"
                        />
                    </h2>
                </div>
                
                <group string="Route">
                    <group>
                        <field name="origin_locality" readonly="order_confirmed" context="{'order_by':'tms_order_count desc, name'}"/>
                    </group>
                    <group>
                        <field name="destination_locality" readonly="order_confirmed" />
                    </group>
                </group>
                <group string="Details">
                    <group> 
                        <field name="product_id" domain="[('trucking_trip','=',True)]"/>
                        <field name="pricelist_id"/>
                        <field name="price_unit"/>
                        
                    </group>
                    <group>
                        <field name="commitment_date" widget="datetime" options="{'show_time': false}"/>
                        <field name="qty" />
                        <field name="distance" />
                    </group>
                </group>
                
                <footer>
                    <button type="object" name="create_sale_order"
                        string="Save"
                        class="btn-primary"
                        data-hotkey="q"
                    />
                    <button
                        string="Cancel"
                        class="btn-secondary"
                        special="cancel"
                        data-hotkey="x"
                    />
                </footer>
            </form>
        </field>
    </record>
    <record id="actrion_create_so" model="ir.actions.act_window">
        <field name="name">Trip information</field>
        <field name="res_model">trucking.create.so</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="trucking_create_so_form" />
    </record>
</odoo>
                